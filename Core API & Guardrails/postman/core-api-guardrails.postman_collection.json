{
  "info": {
    "name": "Core API & Guardrails",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://localhost:8080/api/posts", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "posts"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorType\": \"USER\",\n  \"authorId\": 1,\n  \"content\": \"My post\"\n}"
        }
      }
    },
    {
      "name": "Add Comment",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://localhost:8080/api/posts/1/comments", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "posts", "1", "comments"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorType\": \"BOT\",\n  \"authorId\": 10,\n  \"content\": \"Bot reply\",\n  \"depthLevel\": 1,\n  \"targetHumanId\": 1\n}"
        }
      }
    },
    {
      "name": "Like Post",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://localhost:8080/api/posts/1/like", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "posts", "1", "like"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"actorType\": \"USER\",\n  \"actorId\": 1\n}"
        }
      }
    }
  ]
}
